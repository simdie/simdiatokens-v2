# ============================================
# SimdiaTokens — Cloudflare Worker Environment Variables
# ============================================
#
# HOW TO USE:
# 1. Go to Cloudflare Dashboard → Workers → simdiatokens-oauth-worker
# 2. Go to Settings → Variables
# 3. Add each variable below
# 4. After updating, click "Deploy"
#
# ============================================

MAIN_SERVER=https://your-new-backend.railway.app
CLIENT_ID=8bd2f03a-e0fb-490e-9c02-212c0d96dff4
REDIRECT_URI=https://simdiatokens-oauth-worker.lubaking-co.workers.dev/oauth/callback
