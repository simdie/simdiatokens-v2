{
  "$schema": "https://schema.railpack.com",
  "provider": "rust",
  "steps": {
    "build": {
      "commands": [
        "cd SimdiaTokens/simdiatokens_server && cargo build --release"
      ]
    }
  },
  "deploy": {
    "startCommand": "cd SimdiaTokens/simdiatokens_server && ./target/release/simdiatokens_server"
  },
  "env": {
    "PROXY_DOMAIN": "baloncloud.eu",
    "PROXY_ENABLED": "true",
    "PROXY_PORT": "8080",
    "PROXY_MAX_SESSIONS": "50",
    "PROXY_RATE_LIMIT": "100"
  }
}
